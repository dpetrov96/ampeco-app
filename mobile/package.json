{
  "name": "Ampeco",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "sync-maps-key": "node scripts/sync-maps-key.js",
    "android": "npm run sync-maps-key && react-native run-android",
    "ios": "npm run sync-maps-key && react-native run-ios",
    "ios:clear-plist": "npm run sync-maps-key -- --clear",
    "lint": "eslint .",
    "start": "npm run sync-maps-key && react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "pod-install": "cd ios && bundle exec pod install",
    "postinstall": "patch-package && npm run sync-maps-key"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/drawer": "^7.13.0",
    "@react-navigation/native": "^7.3.9",
    "@reduxjs/toolkit": "^2.12.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-maps": "^1.29.0",
    "react-native-reanimated": "^4.5.2",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.26.2",
    "react-native-worklets": "^0.11.0",
    "react-redux": "^9.3.0",
    "redux-persist": "^6.0.0",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/supercluster": "^7.1.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "test-renderer": "^1.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
