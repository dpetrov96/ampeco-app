+/**
+ * Bridgeless-safe image load + cache.
+ * Empty UIImage placeholders make GMSMarker fall back to the default red pin,
+ * so callers must keep map=nil until a real icon is ready.
+ */
+static NSCache<NSString *, UIImage *> *AIRGoogleMapIconCache(void) {
+    static NSCache<NSString *, UIImage *> *cache;
+    static dispatch_once_t onceToken;
+    dispatch_once(&onceToken, ^{
+        cache = [[NSCache alloc] init];
+        cache.countLimit = 256;
+    });
+    return cache;
+}
+
+static UIImage *AIRGoogleMapImageFromURISync(NSString *uri) {
+    if (uri.length == 0) {
+        return nil;
+    }
+    UIImage *cached = [AIRGoogleMapIconCache() objectForKey:uri];
+    if (cached) {
+        return cached;
+    }
+
+    // Runtime-rasterized badges (JS data URI) — sync decode, no network.
+    if ([uri hasPrefix:@"data:"]) {
+        NSRange comma = [uri rangeOfString:@","];
+        if (comma.location == NSNotFound) {
+            return nil;
+        }
+        NSString *b64 = [uri substringFromIndex:comma.location + 1];
+        NSData *data = [[NSData alloc] initWithBase64EncodedString:b64
+                                                           options:NSDataBase64DecodingIgnoreUnknownCharacters];
+        UIImage *image = data ? [UIImage imageWithData:data scale:RCTScreenScale()] : nil;
+        if (image) {
+            [AIRGoogleMapIconCache() setObject:image forKey:uri];
+        }
+        return image;
+    }
+
+    NSURL *url = [NSURL URLWithString:uri];
+    if (!url.isFileURL) {
+        return nil;
+    }
+    NSData *data = [NSData dataWithContentsOfFile:url.path];
+    UIImage *image = data ? [UIImage imageWithData:data scale:RCTScreenScale()] : nil;
+    if (image) {
+        [AIRGoogleMapIconCache() setObject:image forKey:uri];
+    }
+    return image;
+}
+
+static void (^AIRGoogleMapLoadImage(NSString *uri, void (^completion)(UIImage *image, NSError *error)))(void) {
+    if (uri.length == 0) {
+        completion(nil, nil);
+        return ^{};
+    }
+
+    UIImage *ready = AIRGoogleMapImageFromURISync(uri);
+    if (ready) {
+        // Synchronous — avoids one-frame default Google pin flash.
+        completion(ready, nil);
+        return ^{};
+    }
+
+    NSURL *url = [NSURL URLWithString:uri];
+    if (url == nil) {
+        NSError *error = [NSError errorWithDomain:@"AIRGoogleMapMarker"
+                                             code:1
+                                         userInfo:@{NSLocalizedDescriptionKey: @"Invalid image URI"}];
+        completion(nil, error);
+        return ^{};
+    }
+
+    NSURLSessionDataTask *task =
+        [[NSURLSession sharedSession] dataTaskWithURL:url
+                                    completionHandler:^(NSData *data, NSURLResponse *response, NSError *error) {
+            UIImage *image = nil;
+            if (data != nil && error == nil) {
+                image = [UIImage imageWithData:data scale:RCTScreenScale()];
+                if (image) {
+                    [AIRGoogleMapIconCache() setObject:image forKey:uri];
+                }
+            }
+            dispatch_async(dispatch_get_main_queue(), ^{
+                completion(image, error);
+            });
+        }];
+    [task resume];
+    return ^{
+        [task cancel];
+    };
+}
